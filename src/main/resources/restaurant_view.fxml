<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="998.0" prefWidth="1791.0" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.javafx.RestaurantController">

    <TableView fx:id="foodOrdersTable" layoutX="24.0" layoutY="88.0" prefHeight="350.0" prefWidth="1082.0">
        <columns>
            <TableColumn fx:id="idColumn" prefWidth="55.0" text="ID" />
            <TableColumn fx:id="customerIdColumn" prefWidth="120.0" text="CustomerId" />
            <TableColumn fx:id="restaurantIdColumn" prefWidth="165.0" text="RestaurantId" />
            <TableColumn fx:id="driverIdColumn" prefWidth="105.0" text="DriverId" />
            <TableColumn fx:id="deliveryAddressColumn" prefWidth="105.0" text="Delivery address" />
            <TableColumn fx:id="orderStatusColumn" prefWidth="120.0" text="Order status" />
            <TableColumn fx:id="totalPriceColumn" prefWidth="70.0" text="Total price" />
            <TableColumn fx:id="paymentMethodColumn" prefWidth="95.0" text="Payment method" />
            <TableColumn fx:id="paidColumn" prefWidth="95.0" text="Paid" />
            <TableColumn fx:id="dateCreated" prefWidth="150.0" text="Time created" />
        </columns>
    </TableView>
   <TextField fx:id="deliveryAddressTextField" layoutX="721.0" layoutY="484.0" promptText="Delivery Address" />
   <TextField fx:id="totalPriceTextField" layoutX="547.0" layoutY="484.0" promptText="Total Price" />
   <Button fx:id="createOrderButton" layoutX="955.0" layoutY="484.0" mnemonicParsing="false" onAction="#createOrder" text="Create Order" />
   <CheckBox fx:id="paidCheckBox" layoutX="892.0" layoutY="488.0" mnemonicParsing="false" text="Paid" />
   <Button layoutX="918.0" layoutY="34.0" mnemonicParsing="false" onAction="#cancelSelectedOrder" text="CANCELED" />
   <Button layoutX="817.0" layoutY="34.0" mnemonicParsing="false" onAction="#markSelectedOrderDelivered" text="DELIVERED" />
   <Button layoutX="719.0" layoutY="34.0" mnemonicParsing="false" onAction="#markSelectedOrderPreparing" text="PREPARING" />
   <Button layoutX="622.0" layoutY="34.0" mnemonicParsing="false" onAction="#acceptSelectedOrder" text="ACCEPTED" />
   <Button layoutX="1021.0" layoutY="34.0" mnemonicParsing="false" onAction="#deleteOrder" text="Delete Order" />
   <Label fx:id="currentRestaurantLabel" layoutX="24.0" layoutY="30.0" style="-fx-font-size: 22px; -fx-font-weight: bold;" text="Label">
      <font>
         <Font size="22.0" />
      </font>
   </Label>
   <ComboBox fx:id="customerIdComboBox" layoutX="24.0" layoutY="484.0" prefWidth="150.0" promptText="Customer" />
   <ComboBox fx:id="driverIdComboBox" layoutX="200.0" layoutY="484.0" prefWidth="150.0" promptText="Driver" />
   <ComboBox fx:id="paymentMethodComboBox" layoutX="375.0" layoutY="484.0" prefWidth="150.0" promptText="Payment" />

    <TextField fx:id="menuItemNameTextField" layoutX="24.0" layoutY="581.0" prefWidth="180.0" promptText="Item name" />

    <TextField fx:id="menuItemDescriptionTextField" layoutX="230.0" layoutY="581.0" prefWidth="220.0" promptText="Description" />

    <TextField fx:id="menuItemPriceTextField" layoutX="473.0" layoutY="581.0" prefWidth="120.0" promptText="Price" />

    <CheckBox fx:id="menuItemAvailableCheckBox" layoutX="798.0" layoutY="585.0" selected="true" text="Available" />

    <Button fx:id="addMenuItemButton" layoutX="892.0" layoutY="581.0" mnemonicParsing="false" onAction="#createMenuItem" text="Add Menu Item" />

    <TextField fx:id="quantityTextField" layoutX="622.0" layoutY="581.0" prefHeight="25.0" prefWidth="149.0" promptText="Quantity" />

    <TableView fx:id="menuItemsTable" layoutX="24.0" layoutY="659.0" prefHeight="230.0" prefWidth="785.0">
        <columns>
            <TableColumn fx:id="nameColumn" prefWidth="115.0" text="Name" />
            <TableColumn fx:id="descriptionColumn" prefWidth="114.0" text="Description" />
            <TableColumn fx:id="priceColumn" prefWidth="141.0" text="Price" />
            <TableColumn fx:id="availableColumn" prefWidth="132.0" text="Available" />
        </columns>
    </TableView>

    <TableView fx:id="orderItemsTable" layoutX="1126.0" layoutY="88.0" prefHeight="350.0" prefWidth="372.0">
        <columns>
            <TableColumn fx:id="orderItemMenuIdColumn" prefWidth="115.0" text="Menu Item ID" />
            <TableColumn fx:id="orderItemMenuNameColumn" prefWidth="115.0" text="Menu Item Name" />
            <TableColumn fx:id="orderItemQuantityColumn" prefWidth="114.0" text="Quantity" />
            <TableColumn fx:id="orderItemUnitPriceColumn" prefWidth="141.0" text="Unit Price" />

        </columns>
    </TableView>

</AnchorPane>
