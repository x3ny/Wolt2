<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="520.0" prefWidth="900.0" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.javafx.AdminPanelController">
   <children>
      <Label layoutX="24.0" layoutY="20.0" text="Admin panel" style="-fx-font-size: 22px; -fx-font-weight: bold;" />
      <Label fx:id="usersCountLabel" layoutX="24.0" layoutY="58.0" text="Users: 0" />
      <Button layoutX="804.0" layoutY="48.0" mnemonicParsing="false" onAction="#refreshUsers" prefWidth="72.0" text="Refresh" />

      <TableView fx:id="usersTable" layoutX="24.0" layoutY="88.0" prefHeight="400.0" prefWidth="852.0">
         <columns>
            <TableColumn fx:id="idColumn" prefWidth="55.0" text="ID" />
            <TableColumn fx:id="usernameColumn" prefWidth="120.0" text="Username" />
            <TableColumn fx:id="loginColumn" prefWidth="110.0" text="Login" />
            <TableColumn fx:id="emailColumn" prefWidth="165.0" text="Email" />
            <TableColumn fx:id="firstNameColumn" prefWidth="105.0" text="First name" />
            <TableColumn fx:id="lastNameColumn" prefWidth="105.0" text="Last name" />
            <TableColumn fx:id="phoneNumberColumn" prefWidth="120.0" text="Phone" />
            <TableColumn fx:id="activeColumn" prefWidth="70.0" text="Active" />
            <TableColumn fx:id="adminColumn" prefWidth="95.0" text="Admin" />
         </columns>
      </TableView>
   </children>
</AnchorPane>
