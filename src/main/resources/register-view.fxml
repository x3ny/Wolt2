<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="280.0" prefWidth="400.0" xmlns="http://javafx.com/javafx/24" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.javafx.RegisterController">
   <children>
      <Label layoutX="45.0" layoutY="43.0" text="Username:" />
      <TextField fx:id="usernameField" layoutX="170.0" layoutY="39.0" promptText="Username" />

      <Label layoutX="45.0" layoutY="83.0" text="Email:" />
      <TextField fx:id="emailField" layoutX="170.0" layoutY="79.0" promptText="Email" />

      <Label layoutX="45.0" layoutY="123.0" text="Password:" />
      <PasswordField fx:id="passwordField" layoutX="170.0" layoutY="119.0" promptText="Password" />

      <Label layoutX="45.0" layoutY="163.0" text="Confirm password:" />
      <PasswordField fx:id="confirmPasswordField" layoutX="170.0" layoutY="159.0" promptText="Confirm password" />

      <Button fx:id="registerButton" layoutX="170.0" layoutY="205.0" mnemonicParsing="false" onAction="#register" text="Register" />
      <Label fx:id="messageLabel" layoutX="170.0" layoutY="242.0" />
   </children>
</AnchorPane>
